# Configuration file for ddclient generated by debconf
#
# /etc/ddclient.conf

daemon=60 \
syslog=yes \
pid=/var/run/ddclient.pid \
ssl=yes \
use=web \
web=https://checkip.amazonaws.com/ \
protocol=cloudflare \
zone=mandariini.uk \
ttl=1 \
login=token \
password='{{ ddclient_password }}' \
{{ ddclient_address }}
